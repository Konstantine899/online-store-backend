NODE_ENV=development
PORT=5000
COOKIE_PARSER_SECRET_KEY=dev_cookie_secret

# Development БД (локальный Docker на порту 3307)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_DATABASE=online_store_dev
